---
// SPDX-FileCopyrightText: 2026 SecPal
// SPDX-FileCopyrightText: Tailwind Labs Inc.
// SPDX-License-Identifier: AGPL-3.0-or-later AND LicenseRef-TailwindPlus
// Header block based on Tailwind Plus UI Blocks — "With call-to-action"
// Source: https://tailwindcss.com/plus/ui-blocks/marketing/elements/headers
import type { Locale } from "../i18n/index.ts";
import { useTranslations, getLocalizedPath } from "../i18n/index.ts";

interface Props {
  locale: Locale;
  currentPath?: string;
}

const { locale, currentPath = "/" } = Astro.props;
const t = useTranslations(locale);

const otherLocale: Locale = locale === "en" ? "de" : "en";
const otherLocalePath = getLocalizedPath(currentPath, otherLocale);
const progressPath = `${getLocalizedPath("/", locale)}#progress`;
const updatesPath = `${getLocalizedPath("/", locale)}#updates`;
---

<!-- @tailwindplus/elements is loaded in Base.astro via script tag -->
<header class="bg-white dark:bg-gray-900">
  <nav
    aria-label="Global"
    class="mx-auto flex max-w-7xl items-center justify-between gap-x-6 px-6 py-[var(--secpal-nav-padding-y)] lg:px-8"
  >
    <!-- Logo -->
    <div class="flex lg:flex-1">
      <a href={getLocalizedPath("/", locale)} class="-m-1.5 p-1.5">
        <span class="sr-only">GuardGuide</span>
        <img
          src="/logo-light-48.png"
          class="h-[var(--secpal-nav-logo-height)] w-auto dark:hidden"
          alt="GuardGuide"
        />
        <img
          src="/logo-dark-48.png"
          class="hidden h-[var(--secpal-nav-logo-height)] w-auto dark:block"
          alt=""
          aria-hidden="true"
        />
      </a>
    </div>

    <!-- Desktop nav links -->
    <div class="hidden lg:flex lg:gap-x-12">
      <a
        href={progressPath}
        class="text-sm/6 font-semibold text-gray-900 dark:text-white"
        >{t.nav.progress}</a
      >
      <a
        href={getLocalizedPath("/roadmap", locale)}
        class="text-sm/6 font-semibold text-gray-900 dark:text-white"
        >{t.nav.roadmap}</a
      >
      <a
        href={updatesPath}
        class="text-sm/6 font-semibold text-gray-900 dark:text-white"
        >{t.nav.updates}</a
      >
      <a
        href="https://github.com/SecPal/guardguide.de"
        class="text-sm/6 font-semibold text-gray-900 dark:text-white"
        >{t.nav.github}</a
      >
    </div>

    <!-- Right-side: language switcher + dark toggle + CTA -->
    <div class="flex flex-1 items-center justify-end gap-x-4">
      <!-- Language switcher -->
      <a
        href={otherLocalePath}
        class="hidden text-xs font-semibold uppercase tracking-wide text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white lg:block"
        aria-label={otherLocale === "de"
          ? "Auf Deutsch wechseln"
          : "Switch to English"}
      >
        {otherLocale}
      </a>

      <!-- Dark mode toggle -->
      <button
        id="dark-toggle"
        type="button"
        aria-label={t.nav.toggleDarkMode}
        class="rounded-md p-1.5 text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white"
      >
        <!-- Sun — shown in dark mode -->
        <svg
          class="hidden size-5 dark:block"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"
          ></path>
        </svg>
        <!-- Moon — shown in light mode -->
        <svg
          class="block size-5 dark:hidden"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"
          ></path>
        </svg>
      </button>

      <a
        href="https://github.com/SecPal/guardguide.de"
        class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:hover:bg-indigo-400 dark:focus-visible:outline-indigo-500"
        >{t.nav.followProgress}</a
      >
    </div>

    <!-- Mobile menu button -->
    <div class="flex lg:hidden">
      <button
        type="button"
        onclick="document.getElementById('mobile-menu').classList.remove('hidden')"
        class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-gray-700 dark:text-gray-400"
        aria-label={t.nav.openMenu}
      >
        <span class="sr-only">{t.nav.openMenu}</span>
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
          class="size-6"
        >
          <path
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden"
    role="dialog"
    aria-modal="true"
    aria-label={t.nav.mobileMenu}
  >
    <div
      class="fixed inset-y-0 right-0 z-50 w-full overflow-y-auto bg-white p-6 sm:max-w-sm sm:ring-1 sm:ring-gray-900/10 dark:bg-gray-900 dark:sm:ring-gray-100/10"
    >
      <div class="flex items-center gap-x-6">
        <a href={getLocalizedPath("/", locale)} class="-m-1.5 p-1.5">
          <span class="sr-only">GuardGuide</span>
          <img
            src="/logo-light-48.png"
            class="h-[var(--secpal-nav-logo-height)] w-auto dark:hidden"
            alt="GuardGuide"
          />
          <img
            src="/logo-dark-48.png"
            class="hidden h-[var(--secpal-nav-logo-height)] w-auto dark:block"
            alt=""
            aria-hidden="true"
          />
        </a>
        <a
          href="https://github.com/SecPal/guardguide.de"
          class="ml-auto rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:hover:bg-indigo-400"
          >{t.nav.followProgress}</a
        >
        <button
          type="button"
          onclick="document.getElementById('mobile-menu').classList.add('hidden')"
          class="-m-2.5 rounded-md p-2.5 text-gray-700 dark:text-gray-400"
          aria-label={t.nav.closeMenu}
        >
          <span class="sr-only">{t.nav.closeMenu}</span>
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
            class="size-6"
          >
            <path
              d="M6 18 18 6M6 6l12 12"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
      <div class="mt-6 flow-root">
        <div class="-my-6 divide-y divide-gray-500/10 dark:divide-white/10">
          <div class="space-y-2 py-6">
            <a
              href={progressPath}
              class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-gray-900 hover:bg-gray-50 dark:text-white dark:hover:bg-white/5"
              >{t.nav.progress}</a
            >
            <a
              href={getLocalizedPath("/roadmap", locale)}
              class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-gray-900 hover:bg-gray-50 dark:text-white dark:hover:bg-white/5"
              >{t.nav.roadmap}</a
            >
            <a
              href={updatesPath}
              class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-gray-900 hover:bg-gray-50 dark:text-white dark:hover:bg-white/5"
              >{t.nav.updates}</a
            >
            <a
              href="https://github.com/SecPal/guardguide.de"
              class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-gray-900 hover:bg-gray-50 dark:text-white dark:hover:bg-white/5"
              >{t.nav.github}</a
            >
            <a
              href="mailto:hello@guardguide.de"
              class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-gray-900 hover:bg-gray-50 dark:text-white dark:hover:bg-white/5"
              >{t.nav.contact}</a
            >
            <!-- Language switcher in mobile menu -->
            <a
              href={otherLocalePath}
              class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-gray-900 hover:bg-gray-50 dark:text-white dark:hover:bg-white/5"
            >
              {otherLocale === "de" ? "Deutsch" : "English"}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
