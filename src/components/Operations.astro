import type { Locale } from "../i18n/index.ts";
import { useTranslations } from "../i18n/index.ts";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="bg-white py-16 sm:py-24 dark:bg-gray-900">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div
      class="grid gap-12 lg:grid-cols-[minmax(0,1.2fr)_minmax(20rem,0.8fr)] lg:gap-16"
    >
      <div>
        <p class="text-sm/6 font-semibold text-indigo-600 dark:text-indigo-400">
          {t.operations.eyebrow}
        </p>
        <h2
          class="mt-2 max-w-3xl text-3xl font-semibold tracking-tight text-balance text-gray-900 sm:text-4xl dark:text-white"
        >
          {t.operations.headline}
        </h2>
        <p class="mt-6 max-w-2xl text-base/7 text-gray-600 dark:text-gray-400">
          {t.operations.intro}
        </p>

        <dl class="mt-10 grid gap-6 sm:grid-cols-2">
          {
            t.operations.items.map((item, index) => (
              <div class={index === 2 ? "sm:col-span-2" : undefined}>
                <dt class="text-base/7 font-semibold text-gray-900 dark:text-white">
                  {item.name}
                </dt>
                <dd class="mt-2 text-base/7 text-gray-600 dark:text-gray-400">
                  {item.description}
                </dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div
        class="rounded-3xl bg-gray-50 p-8 ring-1 ring-gray-200 dark:bg-white/5 dark:ring-white/10"
      >
        <p class="text-sm/6 font-semibold text-indigo-600 dark:text-indigo-400">
          {t.operations.panel.eyebrow}
        </p>
        <h3 class="mt-2 text-2xl font-semibold text-gray-900 dark:text-white">
          {t.operations.panel.title}
        </h3>
        <p class="mt-5 text-base/7 text-gray-600 dark:text-gray-400">
          {t.operations.panel.body}
        </p>
        <ul class="mt-8 space-y-4">
          {
            t.operations.panel.points.map((point) => (
              <li class="flex gap-x-3">
                <svg
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                  class="mt-1 size-5 shrink-0 text-indigo-600 dark:text-indigo-400"
                >
                  <path
                    fill-rule="evenodd"
                    clip-rule="evenodd"
                    d="M16.704 5.29a1 1 0 0 1 .006 1.414l-7.25 7.312a1 1 0 0 1-1.42-.004l-3-3.062A1 1 0 1 1 6.46 9.55l2.29 2.336 6.54-6.59a1 1 0 0 1 1.414-.006Z"
                  />
                </svg>
                <span class="text-sm/6 text-gray-600 dark:text-gray-400">
                  {point}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
