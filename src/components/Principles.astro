import type { Locale } from "../i18n/index.ts";
import { getLocalizedPath, useTranslations } from "../i18n/index.ts";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="border-y border-gray-200 bg-gray-50 py-16 sm:py-24 dark:border-white/10 dark:bg-gray-800/40">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="max-w-3xl">
      <p class="text-sm/6 font-semibold text-indigo-600 dark:text-indigo-400">
        {t.principles.eyebrow}
      </p>
      <h2
        class="mt-2 text-3xl font-semibold tracking-tight text-balance text-gray-900 sm:text-4xl dark:text-white"
      >
        {t.principles.headline}
      </h2>
      <p class="mt-6 text-base/7 text-gray-600 dark:text-gray-400">
        {t.principles.intro}
      </p>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {
        t.principles.items.map((item) => (
          <div class="rounded-2xl border border-gray-200/80 bg-white p-6 dark:border-white/10 dark:bg-white/5">
            <p class="text-base/7 font-semibold text-gray-900 dark:text-white">
              {item.name}
            </p>
            <p class="mt-3 text-base/7 text-gray-600 dark:text-gray-400">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>

    <div class="mt-10">
      <a
        href="https://github.com/SecPal/guardguide.de"
        class="text-sm/6 font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300"
      >
        {t.principles.link}
        <span aria-hidden="true">→</span>
      </a>
      <span class="mx-3 text-gray-300 dark:text-gray-600">/</span>
      <a
        href={getLocalizedPath("/security", locale)}
        class="text-sm/6 font-semibold text-gray-700 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white"
      >
        security.txt
      </a>
    </div>
  </div>
</section>
