{
  "name": "@secpal/guardguide.de",
  "version": "0.0.1",
  "description": "Public website for GuardGuide",
  "private": true,
  "type": "module",
  "author": "SecPal",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/SecPal/guardguide.de.git"
  },
  "homepage": "https://guardguide.de",
  "bugs": {
    "url": "https://github.com/SecPal/guardguide.de/issues"
  },
  "keywords": [
    "guardguide",
    "promo-site",
    "astro",
    "tailwindcss",
    "security-services",
    "security-operations",
    "operations-software"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "npm run generate:og && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "generate:og": "node ./scripts/generate-social-previews.mjs",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "astro check",
    "format": "prettier --write --cache '**/*.{md,yml,yaml,json,ts,tsx,js,jsx,astro}'",
    "test": "node --experimental-strip-types --test tests/**/*.mjs",
    "format:check": "prettier --check '**/*.{md,yml,yaml,json,ts,tsx,js,jsx,astro}'"
  },
  "dependencies": {
    "@tailwindplus/elements": "^1.0.0",
    "astro": "^7.0.9"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/vite": "^4.3.2",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.0",
    "markdownlint-cli": "^0.49.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.1",
    "typescript": "6.0.x"
  },
  "overrides": {
    "anymatch": {
      "picomatch": "^2.3.2"
    },
    "brace-expansion": "5.0.6",
    "defu": "^6.1.7",
    "js-yaml": "4.2.0",
    "micromatch": {
      "picomatch": "^2.3.2"
    },
    "picomatch": "^4.0.4",
    "yaml": "^2.8.3"
  }
}
